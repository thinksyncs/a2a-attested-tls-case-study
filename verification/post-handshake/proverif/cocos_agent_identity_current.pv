(* Minimal ProVerif model for L3 intended-agent identity in the current
   post-handshake Cocos AI aTLS discussion.

   Goal:
   - Separate "valid attestation for the same machine" from "the accepted
     response came from the intended agent / workload / process".

   Scope:
   - The client intends one agent on an attested machine.
   - Two co-resident agents share the same machine-level attestation authority.
   - The attestation payload names the machine measurement, request context,
     and live proof key, but not the intended agent identity.
*)

type skey.
type pkey.

free net: channel.
free intended_agent: bitstring.
free other_agent: bitstring.
free machine_measurement: bitstring.
free skA: skey [private].

fun pk(skey): pkey.
fun ea_request(bitstring, bitstring, bitstring): bitstring [data].
fun attest_payload(bitstring, pkey, bitstring): bitstring [data].
fun authenticator(bitstring): bitstring [data].
fun challenge_payload(bitstring, bitstring): bitstring [data].
fun sign(bitstring, skey): bitstring.
reduc forall m: bitstring, k: skey; checksign(sign(m, k), pk(k)) = m.

event MachineAttestationIssued(bitstring, bitstring, pkey).
event IntendedAgentResponded(bitstring, bitstring, pkey).
event OtherAgentResponded(bitstring, bitstring, pkey).
event ClientTargetsAgent(bitstring, bitstring, bitstring).
event ClientAcceptsIntendedAgent(bitstring, bitstring, bitstring, pkey).

let IntendedAgent =
  new skE: skey;
  in(net, ea_request(target_agent: bitstring, chan_id_from_client: bitstring, req_ctx: bitstring));
  let pkE = pk(skE) in
  event MachineAttestationIssued(machine_measurement, req_ctx, pkE);
  out(net, authenticator(sign(attest_payload(machine_measurement, pkE, req_ctx), skA)));
  in(net, challenge_payload(=chan_id_from_client, challenge: bitstring));
  event IntendedAgentResponded(intended_agent, chan_id_from_client, pkE);
  out(net, sign(challenge_payload(chan_id_from_client, challenge), skE)).

let OtherAgent =
  new skE: skey;
  in(net, ea_request(target_agent: bitstring, chan_id_from_client: bitstring, req_ctx: bitstring));
  let pkE = pk(skE) in
  event MachineAttestationIssued(machine_measurement, req_ctx, pkE);
  out(net, authenticator(sign(attest_payload(machine_measurement, pkE, req_ctx), skA)));
  in(net, challenge_payload(=chan_id_from_client, challenge: bitstring));
  event OtherAgentResponded(other_agent, chan_id_from_client, pkE);
  out(net, sign(challenge_payload(chan_id_from_client, challenge), skE)).

let Client =
  new chan_id: bitstring;
  new req_ctx: bitstring;
  new challenge: bitstring;
  event ClientTargetsAgent(intended_agent, chan_id, req_ctx);
  out(net, ea_request(intended_agent, chan_id, req_ctx));
  in(net, auth: bitstring);
  let authenticator(att: bitstring) = auth in
  let attest_payload(=machine_measurement, pkE: pkey, =req_ctx) = checksign(att, pk(skA)) in
  out(net, challenge_payload(chan_id, challenge));
  in(net, resp: bitstring);
  if checksign(resp, pkE) = challenge_payload(chan_id, challenge) then
    event ClientAcceptsIntendedAgent(intended_agent, chan_id, req_ctx, pkE).

query chan_q: bitstring, ctx_q: bitstring, pkE_q: pkey;
  event(ClientAcceptsIntendedAgent(intended_agent, chan_q, ctx_q, pkE_q))
  ==> event(MachineAttestationIssued(machine_measurement, ctx_q, pkE_q)).

query chan_q: bitstring, ctx_q: bitstring, pkE_q: pkey;
  event(ClientAcceptsIntendedAgent(intended_agent, chan_q, ctx_q, pkE_q))
  ==> event(IntendedAgentResponded(intended_agent, chan_q, pkE_q)).

process
  (!IntendedAgent) | (!OtherAgent) | (!Client)
